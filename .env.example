# Bibliography Search MCP - Environment Variables

# 百度学术 API Key (for Chinese literature search)
# https://console.bce.baidu.com/ai-search/qianfan/ais/console/apiKey
BAIDU_API_KEY=your_baidu_api_key_here

# Groq API Key (for LLM-based query analysis)
# https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# OpenAlex 邮箱 (optional, raises rate limits)
# OPENALEX_EMAIL=your_email@example.com
